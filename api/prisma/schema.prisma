generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Element {
  id              Int      @id
  name            String
  symbol          String
  atomicNumber    Int      @unique
  atomicMass      Float?
  category        String
  period          Int?
  groupNumber     Int?
  stateAtRoomTemp String?
  isRadioactive   Boolean  @default(false)
  isSynthetic     Boolean  @default(false)

  cardClass       String?
  electronCost    Int?
  attack          Int?
  healthPoints    Int?
  rarity          String   @default("common")
  decayCounter    Int?
  decayProductId  Int?

  elementDescription  String?
  whereFound          String?
  usedFor             String?
  funFact             String?

  characterName       String?
  loreDescription     String?
  abilityName         String?
  abilityDescription  String?
  abilityType         String?
  abilityNotes        String?

  artworkUrl      String?
  artworkStatus   String   @default("needed")

  cardStatus      String   @default("draft")
  designNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  personRelations      PersonElement[]
  characterReferences  CharacterReference[]
}

model Person {
  id              Int      @id @default(autoincrement())
  name            String
  born            Int?
  died            Int?
  nationality     String?

  biography       String?
  contribution    String?
  gameAngle       String?
  funFact         String?
  relatedElements String?

  artworkUrl      String?
  artworkStatus   String   @default("needed")
  cardStatus      String   @default("draft")
  designNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  elementRelations PersonElement[]
}

model CharacterReference {
  id            Int      @id @default(autoincrement())
  element       Element  @relation(fields: [elementId], references: [id], onDelete: Cascade)
  elementId     Int
  characterName String
  showOrMovie   String?
  actorName     String?
  notes         String?
  addedBy       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// relation types: discovered | co_discovered | isolated | named | named_after | synthesized
model PersonElement {
  id        Int     @id @default(autoincrement())
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  Int
  element   Element @relation(fields: [elementId], references: [id], onDelete: Cascade)
  elementId Int
  relation  String  @default("related")

  @@unique([personId, elementId])
}
